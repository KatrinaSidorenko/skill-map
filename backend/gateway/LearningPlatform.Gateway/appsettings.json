{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Clusters": {
      "core": {
        "Destinations": {
          "core-instance-1": {
            "Address": "http://localhost:5263"
          }
        }
      },
      "workspace-ws": {
        "Destinations": {
          "workspace-ws-instance-1": {
            "Address": "http://localhost:5186"
          }
        }
      }
    },
    "Routes": {
      "workspace-hub": {
        "ClusterId": "workspace-ws",
        "Match": {
          "Path": "api/hubs/workspace/{**catch-all}"
        }
      },
      "roadmaps-workspace": {
        "ClusterId": "core",
        "Match": {
          "Path": "api/roadmaps-workspace/{**catch-all}"
        }
      },
      "roadmap-blueprints": {
        "ClusterId": "core",
        "Match": {
          "Path": "api/roadmap-blueprints/{**catch-all}"
        }
      },
      "personal-roadmaps": {
        "ClusterId": "core",
        "Match": {
          "Path": "api/personal-roadmaps/{**catch-all}"
        }
      },
      "assessments": {
        "ClusterId": "core",
        "Match": {
          "Path": "api/assessments/{**catch-all}"
        }
      },
      "account": {
        "ClusterId": "core",
        "Match": {
          "Path": "api/account/{**catch-all}"
        }
      }
    }
  }
}
